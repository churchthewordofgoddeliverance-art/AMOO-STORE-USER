# ============================================
# AMOO STORE - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# 1. SUPABASE DATABASE CONFIGURATION
# ============================================
# Get these from: https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# 2. BREVO EMAIL SERVICE (for notifications)
# ============================================
# Get API Key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=amoostore5@gmail.com
BREVO_SENDER_NAME=AMOO STORE

# ============================================
# 3. NODE.JS SERVER CONFIGURATION
# ============================================
NODE_ENV=production
PORT=3000
SERVER_URL=https://amoo-store-user-i18d.onrender.com

# ============================================
# 4. FRONTEND URLS (for CORS & redirects)
# ============================================
ADMIN_DASHBOARD_URL=https://admin.onrender.com
RIDER_DASHBOARD_URL=https://rider.onrender.com
CLIENT_URL=https://shop.onrender.com

# ============================================
# 5. TWILIO SMS CONFIGURATION (Optional)
# ============================================
# Sign up at https://www.twilio.com/ to get these
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=your_messaging_service_id

# ============================================
# 6. WHATSAPP SERVICE (Optional)
# ============================================
# Using Twilio or another provider
WHATSAPP_PHONE_NUMBER=your_whatsapp_number
WHATSAPP_API_KEY=your_whatsapp_api_key

# ============================================
# 7. ADMIN CREDENTIALS (Initial Setup)
# ============================================
# Create admin user with these credentials
ADMIN_EMAIL=admin@amoostore.com
ADMIN_PASSWORD=your_secure_password_here

# ============================================
# 8. PAYMENT GATEWAY (Optional - if needed)
# ============================================
# STRIPE_SECRET_KEY=sk_live_xxxxx
# STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
# PAYPAL_CLIENT_ID=your_paypal_id
# PAYPAL_SECRET=your_paypal_secret

# ============================================
# 9. LOGGING & DEBUG (Optional)
# ============================================
# LOG_LEVEL=info
# DEBUG=amoostore:*
